# ==========================================
# S.A.I. Environmental Configuration
# ==========================================

# 1. LLM Provider Configuration
# Options: openai, gemini, ollama, anthropic
SAI_PROVIDER=openai

# Model ID
# Note: Local proxies usually support 'gpt-4' or 'gpt-3.5-turbo'
MODEL_NAME=gpt-4o

# OpenAI Settings (pointing to your local Copilot API)
OPENAI_API_KEY=local-token
OPENAI_BASE_URL=http://localhost:4141/v1

# Other AI Providers
GEMINI_API_KEY=your_gemini_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# 2. Autonomous Identity & Notifications
# Used for S.A.I.'s native email operations and GitHub publishing
SAI_EMAIL="sai.agent@gmail.com"
SAI_EMAIL_PASSWORD="your-16-char-app-password"
YOUR_ADMIN_EMAIL="admin@example.com"

SAI_GITHUB_USERNAME="sai-bot"
SAI_GITHUB_TOKEN="ghp_xxxxxx"
